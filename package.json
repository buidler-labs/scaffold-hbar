{
  "name": "sh",
  "version": "0.0.1",
  "private": true,
  "workspaces": {
    "packages": [
      "packages/hardhat",
      "packages/nextjs",
      "packages/foundry"
    ]
  },
  "scripts": {
    "account": "yarn hardhat:account",
    "account:import": "yarn workspace @sh/hardhat account:import",
    "account:generate": "yarn workspace @sh/hardhat account:generate",
    "account:reveal-pk": "yarn workspace @sh/hardhat account:reveal-pk",
