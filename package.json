    "vercel:login": "npm run --workspace=packages/nextjs vercel:login",
    "verify": "npm run foundry:verify",
    "verify:testnet": "npm run --workspace=packages/foundry verify:testnet",
    "verify:mainnet": "npm run --workspace=packages/foundry verify:mainnet",
    "verify:contract": "npm run --workspace=packages/foundry verify:contract"
