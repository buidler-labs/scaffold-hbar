    "compile": "yarn hardhat:compile",
    "deploy": "yarn hardhat:deploy",
    "foundry:compile": "yarn workspace @sh/foundry compile",
    "foundry:test": "yarn workspace @sh/foundry test",
    "foundry:test:local": "yarn workspace @sh/foundry test:local",
    "foundry:test:testnet": "yarn workspace @sh/foundry test:testnet",
    "foundry:test:mainnet": "yarn workspace @sh/foundry test:mainnet",
    "foundry:deploy": "yarn workspace @sh/foundry deploy",
    "foundry:clean": "yarn workspace @sh/foundry clean",
    "fork": "yarn hardhat:fork",
    "format": "yarn next:format && yarn hardhat:format",
    "generate": "yarn account:generate",
    "hardhat:account": "yarn workspace @sh/hardhat account",
    "hardhat:chain": "yarn workspace @sh/hardhat chain",
    "hardhat:check-types": "yarn workspace @sh/hardhat check-types",
    "hardhat:clean": "yarn workspace @sh/hardhat clean",
    "hardhat:compile": "yarn workspace @sh/hardhat compile",
    "hardhat:deploy": "yarn workspace @sh/hardhat deploy",
    "hardhat:flatten": "yarn workspace @sh/hardhat flatten",
    "hardhat:fork": "yarn workspace @sh/hardhat fork",
    "hardhat:format": "yarn workspace @sh/hardhat format",
    "hardhat:generate": "yarn workspace @sh/hardhat generate",
    "hardhat:hardhat-verify": "yarn workspace @sh/hardhat hardhat-verify",
    "hardhat:lint": "yarn workspace @sh/hardhat lint",
    "hardhat:lint-staged": "yarn workspace @sh/hardhat lint-staged",
    "hardhat:test": "yarn workspace @sh/hardhat test",
    "hardhat:verify": "yarn workspace @sh/hardhat verify",
    "lint": "yarn next:lint && yarn hardhat:lint",
    "next:build": "yarn workspace @sh/nextjs build",
    "next:check-types": "yarn workspace @sh/nextjs check-types",
    "next:format": "yarn workspace @sh/nextjs format",
    "next:lint": "yarn workspace @sh/nextjs lint",
    "next:serve": "yarn workspace @sh/nextjs serve",
    "postinstall": "husky",
    "precommit": "lint-staged",
