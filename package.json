{
  "name": "sh",
  "version": "0.0.1",
  "private": true,
  "workspaces": {
    "packages": [
      "packages/nextjs"
    ]
  },
  "scripts": {
    "format": "yarn next:format",
    "lint": "yarn next:lint",
    "next:build": "yarn workspace @sh/nextjs build",
    "next:check-types": "yarn workspace @sh/nextjs check-types",
    "next:format": "yarn workspace @sh/nextjs format",
    "next:lint": "yarn workspace @sh/nextjs lint",
    "next:serve": "yarn workspace @sh/nextjs serve",
    "postinstall": "husky",
    "precommit": "lint-staged",
    "lint-staged": "lint-staged",
    "start": "yarn workspace @sh/nextjs dev",
    "vercel": "yarn workspace @sh/nextjs vercel",
    "vercel:yolo": "yarn workspace @sh/nextjs vercel:yolo",
    "ipfs": "yarn workspace @sh/nextjs ipfs",
    "vercel:login": "yarn workspace @sh/nextjs vercel:login"
  },
  "packageManager": "yarn@3.2.3",
  "devDependencies": {
    "husky": "^9.1.6",
    "lint-staged": "^15.2.10"
  },
  "engines": {
    "node": ">=20.18.3"
  }
}
