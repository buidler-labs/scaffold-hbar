{
  "compilerOptions": {
    "target": "es2020",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "paths": {
      "~~/*": ["./*"],
      "~~/hooks/scaffold-hbar": ["./hooks/scaffold-eth/index.ts"],
      "~~/hooks/scaffold-hbar/*": ["./hooks/scaffold-eth/*"],
      "~~/utils/scaffold-hbar": ["./utils/scaffold-eth/index.ts"],
      "~~/utils/scaffold-hbar/*": ["./utils/scaffold-eth/*"],
      "~~/components/scaffold-hbar": ["./components/scaffold-eth/index.tsx"],
      "~~/components/scaffold-hbar/*": ["./components/scaffold-eth/*"]
    },
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
  "exclude": ["node_modules"]
}
